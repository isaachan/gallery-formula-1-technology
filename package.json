{
  "name": "gallery-formula-1-technology",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": "22.22.0",
    "npm": "10.9.4"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "ci": "npm run format && npm run lint && npm run typecheck && npm run test && npm run validate:content && npm run build",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "mkdir -p .next/types && touch .next/types/routes.d.ts && next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "validate:content": "node tools/content/validate-content.mjs",
    "content:new": "node tools/content/scaffold-content.mjs",
    "content:correction": "node tools/content/record-correction.mjs",
    "perf:timeline": "npm run build && node tools/perf/verify-timeline-performance.mjs",
    "perf:routes": "npm run build && node tools/perf/verify-route-performance.mjs",
    "ops:check-assets": "node tools/ops/check-asset-health.mjs",
    "ops:rights-report": "node tools/ops/report-rights-expiry.mjs",
    "ops:smoke": "node tools/ops/smoke-test.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "3.2.4",
    "axe-core": "^4.12.1",
    "chrome-launcher": "^1.1.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "jsdom": "26.1.0",
    "lighthouse": "^12.8.2",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
