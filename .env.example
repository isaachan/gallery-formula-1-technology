NEXT_PUBLIC_SITE_URL=http://localhost:3000
CONTENT_ROOT=content
# Set to true to include draft content in local/protected preview environments.
# Production should leave this unset so only published content is visible.
CONTENT_INCLUDE_DRAFTS=false
# Comma-separated list of remote origins media assets are allowed to reference.
# Local/repository-relative paths under public/ are always allowed; any other
# remote origin must be added here explicitly (see docs/ARCHITECTURE.md).
CONTENT_MEDIA_ALLOWED_ORIGINS=
